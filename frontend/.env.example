# Single place to control all frontend API calls
# For local dev with Vercel rewrites style:
REACT_APP_API_BASE_URL=/api

# Optional alternatives (keep commented if using API_BASE_URL)
# REACT_APP_API_GATEWAY_URL=http://localhost:8081
# REACT_APP_API_PROXY_BASE=/api
# REACT_APP_AUTH_API_URL=http://localhost:3001/api/auth
# REACT_APP_EVENT_API_URL=http://localhost:3002/api/events
# REACT_APP_BOOKING_API_URL=http://localhost:3003/api/bookings
# REACT_APP_REVIEW_API_URL=http://localhost:3004/api/reviews
